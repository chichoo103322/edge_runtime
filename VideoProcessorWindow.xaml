<Window x:Class="edge_runtime.VideoProcessorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="视频处理编辑器"
        Width="1200" Height="800"
        Background="#FF050A1A">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题栏 -->
        <Border Grid.Row="0" Background="#0A1633" Padding="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button x:Name="BtnReturnHome" Content="返回主页" Width="110" Height="36" Grid.Column="0"
                        Background="#34495E" Foreground="White" BorderThickness="0" />

                <TextBlock Text="视频处理编辑器" FontSize="18" FontWeight="Bold" Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Center" Grid.Column="1"/>
            </Grid>
        </Border>

        <!-- 视频预览区 -->
        <Border Grid.Row="1" Margin="12" Background="Black" CornerRadius="6" BorderBrush="#1B2B4A" BorderThickness="2">
            <Grid>
                <!-- MediaElement 用于播放导入的视频文件 -->
                <MediaElement x:Name="VideoPlayer" LoadedBehavior="Manual" Stretch="Uniform"/>
                <!-- Image 用于显示实时摄像头画面 -->
                <Image x:Name="CameraPreview" Stretch="Uniform" Visibility="Collapsed"/>
            </Grid>
        </Border>

        <!-- 底部控制区：包含进度条和播放控制 -->
        <Border Grid.Row="2" Background="#0A1633" Padding="8" Margin="10">
            <StackPanel Orientation="Vertical">
                <!-- 进度条区域 -->
                <Grid Margin="4" VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Slider x:Name="TimelineSlider" Grid.Column="0" Minimum="0" Maximum="1000" Value="0" Margin="6,0,12,0" VerticalAlignment="Center"
                            IsSnapToTickEnabled="False" TickFrequency="1" LargeChange="10" SmallChange="1"
                            PreviewMouseDown="TimelineSlider_PreviewMouseDown" 
                            PreviewMouseUp="TimelineSlider_PreviewMouseUp"
                            ValueChanged="TimelineSlider_ValueChanged"/>

                    <TextBlock x:Name="TxtCurrentTime" Grid.Column="1" Text="00:00.000" Foreground="White" VerticalAlignment="Center" Margin="6,0" FontFamily="Consolas"/>
                    <TextBlock x:Name="TxtTotalTime" Grid.Column="2" Text="00:00.000" Foreground="White" VerticalAlignment="Center" Margin="8,0,6,0" FontFamily="Consolas"/>
                </Grid>

                <!-- 截取控制区域 -->
                <Grid Margin="4" VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Button x:Name="BtnMarkStart" Grid.Column="0" Content="📍 标记起点" Margin="6,0" Padding="10,4" 
                            Background="#8E44AD" Foreground="White" BorderThickness="0"/>
                    <TextBlock x:Name="TxtStartTime" Grid.Column="1" Text="起点: --:--" Foreground="#9B59B6" 
                               VerticalAlignment="Center" Margin="6,0" FontFamily="Consolas" FontSize="12"/>

                    <Button x:Name="BtnMarkEnd" Grid.Column="3" Content="📍 标记终点" Margin="6,0" Padding="10,4" 
                            Background="#8E44AD" Foreground="White" BorderThickness="0"/>
                    <TextBlock x:Name="TxtEndTime" Grid.Column="4" Text="终点: --:--" Foreground="#9B59B6" 
                               VerticalAlignment="Center" Margin="6,0" FontFamily="Consolas" FontSize="12"/>

                    <Button x:Name="BtnExportClip" Grid.Column="5" Content="💾 导出片段" Margin="6,0" Padding="10,4" 
                            Background="#16A085" Foreground="White" BorderThickness="0"/>
                </Grid>

                <!-- 播放/暂停/停止 控件 -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="6">
                    <Button x:Name="BtnImportVideo" Content="📂 导入视频" Margin="6" Padding="12,6" Background="#2980b9" Foreground="White" BorderThickness="0"/>
                    <Button x:Name="BtnPlay" Content="▶ 播放" Margin="6" Padding="12,6" Background="#27AE60" Foreground="White" BorderThickness="0"/>
                    <Button x:Name="BtnPause" Content="⏸ 暂停" Margin="6" Padding="12,6" Background="#F39C12" Foreground="White" BorderThickness="0"/>
                    <Button x:Name="BtnStop" Content="⏹ 停止" Margin="6" Padding="12,6" Background="#E74C3C" Foreground="White" BorderThickness="0"/>
                    <Button x:Name="BtnStartRecording" Content="🔴 开始录制" Margin="6" Padding="12,6" Background="#C0392B" Foreground="White" BorderThickness="0"/>
                    <Button x:Name="BtnStopRecording" Content="⏹ 停止录制" Margin="6" Padding="12,6" Background="#7F8C8D" Foreground="White" BorderThickness="0"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Window>