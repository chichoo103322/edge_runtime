<Window x:Class="edge_runtime.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="EdgeGuard Runtime - 实时监控" Height="1080" Width="1920"
        Background="#050A1A" Foreground="White" WindowState="Maximized">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="3*"/>
            <RowDefinition Height="1*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.2*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" BorderBrush="#1B2B4A" BorderThickness="2" Margin="5" Background="#000">
                <Grid>
                    <Image x:Name="VideoFeed" Stretch="Uniform" />
                    <Border VerticalAlignment="Top" HorizontalAlignment="Left" Background="#CC000000" Padding="10" Margin="10">
                        <TextBlock x:Name="TxtOverlayInfo" Text="当前步骤: 检查零件 (2/4)" Foreground="Lime" FontSize="20"/>
                    </Border>
                    <Border x:Name="ErrorFlashBorder" Background="#55FF0000" Visibility="Collapsed"/>
                </Grid>
            </Border>

            <Border Grid.Column="1" BorderBrush="#1B2B4A" BorderThickness="2" Margin="5" Background="#0A1633">
                <DockPanel>
                    <Border DockPanel.Dock="Top" Background="#1B2B4A" Padding="10">
                        <TextBlock Text="实时工艺流程判定" FontWeight="Bold" FontSize="18"/>
                    </Border>
                    <ScrollViewer>
                        <ItemsControl x:Name="TreeNodesControl" Margin="20">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                                        <Border Width="200" Height="50" CornerRadius="25" BorderThickness="2" Margin="5"
                                                BorderBrush="{Binding StatusColor}" Background="#112244">
                                            <TextBlock Text="{Binding NodeName}" VerticalAlignment="Center" HorizontalAlignment="Center" 
                                                       Foreground="{Binding StatusColor}" FontSize="16" FontWeight="Bold"/>
                                        </Border>
                                        <TextBlock Text="↓" HorizontalAlignment="Center" Foreground="#445577" FontSize="20" 
                                                   Visibility="{Binding IsLast, Converter={StaticResource InverseBoolToVis}}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Grid>

        <Border Grid.Row="1" BorderBrush="#1B2B4A" BorderThickness="2" Margin="5" Background="#0A1633">
            <DockPanel>
                <Border DockPanel.Dock="Top" Background="#0D1B3D" Padding="8">
                    <TextBlock Text="实时告警与生产详情" Foreground="#5DA9FF"/>
                </Border>
                <DataGrid x:Name="LogGrid" AutoGenerateColumns="False" Background="Transparent" 
                          RowBackground="#0A1633" Foreground="White" BorderThickness="0" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#1B2B4A">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="序号" Binding="{Binding Id}" Width="50"/>
                        <DataGridTextColumn Header="流程" Binding="{Binding ProcessName}" Width="150"/>
                        <DataGridTextColumn Header="结果" Binding="{Binding Result}" Width="120"/>
                        <DataGridTextColumn Header="动作状态" Binding="{Binding ActionStatus}" Width="*"/>
                        <DataGridTextColumn Header="开始时间" Binding="{Binding StartTime}" Width="180"/>
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </Border>
    </Grid>
</Window>