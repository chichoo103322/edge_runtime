<Window x:Class="edge_runtime.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:edge_runtime"
    Title="EdgeGuard Runtime - 智能工艺流程监控" Height="1080" Width="1920"
    Background="#050A1A" Foreground="White" WindowState="Maximized">

<Window.Resources>
    <local:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
    <local:InverseBooleanToVisibilityConverter x:Key="InverseBoolToVisibility"/>
    <local:LevelToColorConverter x:Key="LevelToColorConverter"/>
</Window.Resources>

<Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="3*"/>
            <RowDefinition Height="1*"/>
        </Grid.RowDefinitions>

        <!-- 隐藏的视频播放器，用于播放标准作业指导 -->
        <Popup x:Name="VideoPopup" Placement="Center" AllowsTransparency="False" 
               PopupAnimation="Fade" StaysOpen="True" IsOpen="False">
            <Border Background="Black" BorderBrush="#1B2B4A" BorderThickness="2" CornerRadius="10" Width="800" Height="600">
                <Grid Background="Black">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#1B2B4A" Padding="10" CornerRadius="10,10,0,0">
                        <Grid>
                            <TextBlock Text="作业指导视频" Foreground="White" FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
                            <Button HorizontalAlignment="Right" Content="✕" Click="OnCloseVideo_Click" 
                                    Background="#E74C3C" Foreground="White" BorderThickness="0" 
                                    Padding="8" FontSize="14" Width="35" Height="35">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="3"/>
                                    </Style>
                                </Button.Resources>
                            </Button>
                        </Grid>
                    </Border>

                    <Border Grid.Row="1" Background="Black" BorderBrush="#1B2B4A" BorderThickness="0">
                        <MediaElement x:Name="StandardPlayer" Stretch="Uniform" LoadedBehavior="Manual"/>
                    </Border>

                    <Border Grid.Row="2" Background="#1B2B4A" Padding="10" CornerRadius="0,0,10,10">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Button x:Name="BtnPlayVideo" Content="▶ 播放" Click="OnPlayVideo_Click" 
                                    Background="#27AE60" Foreground="White" BorderThickness="0" 
                                    Padding="12,6" FontSize="13" Margin="5">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="3"/>
                                    </Style>
                                </Button.Resources>
                            </Button>
                            <Button x:Name="BtnPauseVideo" Content="⏸ 暂停" Click="OnPauseVideo_Click" 
                                    Background="#F39C12" Foreground="White" BorderThickness="0" 
                                    Padding="12,6" FontSize="13" Margin="5">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="3"/>
                                    </Style>
                                </Button.Resources>
                            </Button>
                            <Button Content="⏹ 停止" Click="OnStopVideo_Click" 
                                    Background="#E74C3C" Foreground="White" BorderThickness="0" 
                                    Padding="12,6" FontSize="13" Margin="5">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="3"/>
                                    </Style>
                                </Button.Resources>
                            </Button>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Popup>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" BorderBrush="#1B2B4A" BorderThickness="2" Margin="5" Background="Black">
                <Grid>
                    <Image x:Name="VideoFeed" Stretch="Uniform" />
                    <StackPanel VerticalAlignment="Top" HorizontalAlignment="Left" Margin="15">
                        <Border Background="#AA000000" CornerRadius="5" Padding="10,5" Margin="0,0,0,10">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📍 工位: " Foreground="#AAAAAA" FontSize="16"/>
                                <TextBlock Text="{Binding CurrentStationName}" Foreground="#00CCFF" FontSize="18" FontWeight="Bold"/>
                            </StackPanel>
                        </Border>
                        <Border Background="#AA000000" Padding="10,5" CornerRadius="5">
                            <TextBlock x:Name="TxtCurrentStep" Text="等待加载..." Foreground="#00FF00" FontSize="20" FontWeight="Bold"/>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Column="1" BorderBrush="#1B2B4A" BorderThickness="2" Margin="5" Background="#0A1633">
                <DockPanel>
                    <Grid DockPanel.Dock="Top" Background="#1B2B4A" Height="60">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0">
                            <TextBlock Text="实时工艺看板" FontSize="24" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                            <Button x:Name="BtnLoad" Content="📂 导入流程 JSON" Click="BtnLoadProject_Click" 
                                    Margin="30,0,0,0" Padding="20,8" Background="#2980b9" Foreground="White" 
                                    BorderThickness="0" FontSize="16">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="5"/>
                                    </Style>
                                </Button.Resources>
                            </Button>
                            <Button x:Name="BtnOpenEditor" Content="✏️ 打开编辑器" Click="BtnOpenEditor_Click" 
                                    Margin="15,0,0,0" Padding="20,8" Background="#E67E22" Foreground="White" 
                                    BorderThickness="0" FontSize="16" ToolTip="打开动作树编辑器">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="5"/>
                                    </Style>
                                </Button.Resources>
                            </Button>
                        </StackPanel>
                    </Grid>
                    <Viewbox Stretch="Uniform" Margin="10" VerticalAlignment="Top">
                        <ItemsControl ItemsSource="{Binding ActionColumns}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#445577" BorderThickness="1" Margin="10" Padding="15" Width="260" Background="#0F1F3D" CornerRadius="8">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Name}" FontSize="24" FontWeight="Bold" 
                                                       HorizontalAlignment="Center" Margin="0,0,0,20" Foreground="#66AAFF"/>
                                            <ItemsControl ItemsSource="{Binding States}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <StackPanel Margin="0,8">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                </Grid.ColumnDefinitions>

                                                                <Border Grid.Column="0" Background="{Binding Background}" 
                                                                        BorderBrush="{Binding BorderColor}" BorderThickness="3"
                                                                        CornerRadius="25" Height="50">
                                                                    <TextBlock Text="{Binding Name}" VerticalAlignment="Center" 
                                                                               HorizontalAlignment="Center" FontWeight="Bold" 
                                                                               FontSize="16" Foreground="White"/>
                                                                </Border>

                                                                <!-- 视频按钮：仅当 HasVideo 为 true 时显示 -->
                                                                <Button Grid.Column="1" Content="🎬" 
                                                                        Click="OnStepVideo_Click" 
                                                                        Tag="{Binding}"
                                                                        Margin="5,0,0,0" Padding="6,4" 
                                                                        Background="#E67E22" Foreground="White" 
                                                                        FontSize="14" BorderThickness="0"
                                                                        Visibility="{Binding HasVideo, Converter={StaticResource BoolToVisibility}}"
                                                                        ToolTip="查看作业指导视频">
                                                                    <Button.Resources>
                                                                        <Style TargetType="Button">
                                                                            <Setter Property="Template">
                                                                                <Setter.Value>
                                                                                    <ControlTemplate TargetType="Button">
                                                                                        <Border Background="{TemplateBinding Background}" 
                                                                                                CornerRadius="5" Padding="{TemplateBinding Padding}">
                                                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                                        </Border>
                                                                                    </ControlTemplate>
                                                                                </Setter.Value>
                                                                            </Setter>
                                                                        </Style>
                                                                    </Button.Resources>
                                                                </Button>
                                                            </Grid>

                                                            <TextBlock Text="⬇" HorizontalAlignment="Center" Foreground="#445577" 
                                                                       FontSize="18" Margin="0,5"/>
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Viewbox>
                </DockPanel>
            </Border>
        </Grid>

        <Grid Grid.Row="1" Margin="5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="350"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" BorderBrush="#1B2B4A" BorderThickness="2" Background="#0A1633" Margin="0,0,5,0">
                <DockPanel>
                    <Border DockPanel.Dock="Top" Background="#1B2B4A" Padding="10" Margin="0,0,0,5">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="📋 系统运行日志" FontWeight="Bold" Foreground="White" FontSize="14"/>
                            <Button Grid.Column="1" Content="清空" Click="BtnClearLogs_Click" 
                                    Background="#34495E" Foreground="White" BorderThickness="0" 
                                    Padding="8,4" FontSize="11">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="3"/>
                                    </Style>
                                </Button.Resources>
                            </Button>
                        </Grid>
                    </Border>
                    <ListBox ItemsSource="{Binding Source={x:Static local:UILogManager.Instance}, Path=Logs}" 
                             Background="Transparent" BorderThickness="0" Margin="5" Foreground="White"
                             ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" FontSize="11" FontFamily="Consolas"
                                           Foreground="{Binding Level, Converter={local:LevelToColorConverter}}"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <Border Grid.Column="1" BorderBrush="#1B2B4A" BorderThickness="2" Background="#0A1633">
                <DockPanel>
                    <Border DockPanel.Dock="Top" Background="#1B2B4A" Padding="10" Margin="0,0,0,5">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="📷 在线设备管理" FontWeight="Bold" Foreground="White" FontSize="16" VerticalAlignment="Center"/>
                            <TextBlock Text=" (自动检测)" Foreground="Gray" FontSize="12" VerticalAlignment="Center" Margin="5,0,0,0"/>
                        </StackPanel>
                    </Border>

                    <ListView ItemsSource="{Binding DeviceList}" Background="Transparent" BorderThickness="0" Margin="5">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#112233" CornerRadius="5" Margin="0,2" Padding="10">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0" Orientation="Vertical">
                                            <TextBlock Text="{Binding DeviceName}" Foreground="White" FontWeight="Bold" FontSize="14"/>
                                            <TextBlock Text="{Binding DeviceId, StringFormat='ID: {0}'}" Foreground="Gray" FontSize="10"/>
                                        </StackPanel>

                                        <Border Grid.Column="1" Background="#22000000" CornerRadius="10" Padding="8,4">
                                            <StackPanel Orientation="Horizontal">
                                                <Ellipse Width="10" Height="10" Fill="{Binding StatusColor}" Margin="0,0,5,0"/>
                                                <TextBlock Text="{Binding Status}" Foreground="{Binding StatusColor}" FontSize="12" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</Window>