<Window x:Class="edge_runtime.ErrorLogViewerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="📷 错误日志查看器" Height="750" Width="1100"
        Background="#050A1A" Foreground="White" WindowStartupLocation="CenterOwner">
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="380"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- 左侧：筛选 + 记录列表 -->
        <DockPanel Grid.Column="0" Margin="0,0,5,0">
            <!-- 筛选栏 -->
            <Border DockPanel.Dock="Top" Background="#1B2B4A" CornerRadius="8" Padding="12" Margin="0,0,0,8">
                <StackPanel>
                    <TextBlock Text="🔍 筛选条件" FontSize="16" FontWeight="Bold" Foreground="White" Margin="0,0,0,8"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="开始日期:" Foreground="#AAAAAA" VerticalAlignment="Center" Margin="0,0,8,6"/>
                        <DatePicker Grid.Row="0" Grid.Column="1" x:Name="DpStartDate" Margin="0,0,0,6" Background="#0A1633"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="结束日期:" Foreground="#AAAAAA" VerticalAlignment="Center" Margin="0,0,8,6"/>
                        <DatePicker Grid.Row="1" Grid.Column="1" x:Name="DpEndDate" Margin="0,0,0,6"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="状态:" Foreground="#AAAAAA" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <ComboBox Grid.Row="2" Grid.Column="1" x:Name="CbStatusFilter" SelectedIndex="0">
                            <ComboBoxItem Content="全部"/>
                            <ComboBoxItem Content="NG"/>
                            <ComboBoxItem Content="TIMEOUT"/>
                        </ComboBox>
                    </Grid>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                        <Button Content="🔄 查询" Click="BtnSearch_Click" 
                                Background="#2980B9" Foreground="White" BorderThickness="0" 
                                Padding="16,6" FontSize="14" Margin="0,0,8,0">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="5"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                        <Button Content="📂 打开目录" Click="BtnOpenFolder_Click" 
                                Background="#27AE60" Foreground="White" BorderThickness="0" 
                                Padding="16,6" FontSize="14">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="5"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- 统计信息 -->
            <Border DockPanel.Dock="Top" Background="#112233" CornerRadius="5" Padding="10" Margin="0,0,0,8">
                <TextBlock x:Name="TxtSummary" Text="共 0 条记录" Foreground="#66AAFF" FontSize="13"/>
            </Border>

            <!-- 记录列表 -->
            <Border Background="#0A1633" BorderBrush="#1B2B4A" BorderThickness="2" CornerRadius="8">
                <ListView x:Name="LvLogs" Background="Transparent" BorderThickness="0" 
                          Foreground="White" SelectionChanged="LvLogs_SelectionChanged"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#112233" CornerRadius="5" Padding="10" Margin="0,2">
                                <StackPanel>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Step}" Foreground="White" 
                                                   FontWeight="Bold" FontSize="14" TextTrimming="CharacterEllipsis"/>
                                        <Border Grid.Column="1" CornerRadius="10" Padding="8,2" 
                                                Background="{Binding StatusColor}">
                                            <TextBlock Text="{Binding Status}" Foreground="White" FontSize="11" FontWeight="Bold"/>
                                        </Border>
                                    </Grid>
                                    <TextBlock Text="{Binding TimeDisplay}" Foreground="#888888" FontSize="11" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Border>
        </DockPanel>

        <!-- 右侧：图片预览 -->
        <Border Grid.Column="1" Background="#0A1633" BorderBrush="#1B2B4A" BorderThickness="2" CornerRadius="8" Margin="5,0,0,0">
            <DockPanel>
                <Border DockPanel.Dock="Top" Background="#1B2B4A" Padding="12" CornerRadius="8,8,0,0">
                    <TextBlock x:Name="TxtImageTitle" Text="选择一条记录查看图片" FontSize="16" FontWeight="Bold" Foreground="White"/>
                </Border>
                <Border DockPanel.Dock="Bottom" Background="#112233" Padding="10" CornerRadius="0,0,8,8">
                    <TextBlock x:Name="TxtImagePath" Text="" Foreground="#888888" FontSize="11" TextTrimming="CharacterEllipsis"/>
                </Border>
                <Grid Background="Black">
                    <TextBlock x:Name="TxtNoImage" Text="暂无图片" 
                               HorizontalAlignment="Center" VerticalAlignment="Center" 
                               Foreground="#555555" FontSize="24"/>
                    <Image x:Name="ImgPreview" Stretch="Uniform" Margin="10"/>
                </Grid>
            </DockPanel>
        </Border>
    </Grid>
</Window>
